# ReYMeN Agent — API Anahtarlari
# Bu dosyayi kopyala: cp .env.example .env  (Linux/Mac)
#                   copy .env.example .env  (Windows)
# Sonra kendi anahtarlarini gir.
# .env dosyasi GITIGNORE'dadir, asla git'e gonderme!

# ============================================================
# ZORUNLU: En az bir LLM provider anahtari
# ============================================================
# DeepSeek (en uyumlu, tavsiye edilen)
# Kayit: https://platform.deepseek.com/api_keys
# Format: sk- ile baslar, orn: sk-abc123def456...
DEEPSEEK_API_KEY=buraya_yaz

# ============================================================
# OPSIYONEL: Telegram Bot Token'lari
# ============================================================
# BotFather'dan al: https://t.me/BotFather
# /newbot ile bot olustur, tokeni buraya yaz
# Format: 1234567890:ABCdefGHIjklmNOPqrstUVWXyz
BOT_TOKEN_REYMEN=buraya_yaz
BOT_TOKEN_PASA=buraya_yaz
BOT_TOKEN_KRAL=buraya_yaz
TELEGRAM_BOT_TOKEN=buraya_yaz

# ============================================================
# OPSIYONEL: Diger LLM provider'lar (yedek)
# ============================================================
# DeepSeek kredisi bitince otomatik gecer.
# Sadece kullanacagin provider'larin key'ini gir, digerlerini yoruma al.
# OPENROUTER_API_KEY=buraya_yaz
# XAI_API_KEY=buraya_yaz
# GROQ_API_KEY=buraya_yaz
# ANTHROPIC_API_KEY=buraya_yaz
# OPENAI_API_KEY=buraya_yaz
# XIAOMI_API_KEY=buraya_yaz

# ============================================================
# OPSIYONEL: Harici servisler
# ============================================================
# FIRECRAWL_API_KEY=buraya_yaz
# FAL_KEY=buraya_yaz
# PERPLEXITY_API_KEY=buraya_yaz

# ============================================================
# AYARLAR
# ============================================================
GATEWAY_ALLOW_ALL_USERS=true
