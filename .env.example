# ─── Required: LLM Provider ─────────────────────────────────────
# At least ONE must be set. DeepSeek recommended (cheapest).
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
#OPENAI_API_KEY=sk-your-openai-api-key
#ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
#XAI_API_KEY=your-xai-grok-key
#OPENROUTER_API_KEY=sk-or-your-openrouter-key
#GROQ_API_KEY=gsk-your-groq-key

# ─── Telegram Bots ───────────────────────────────────────────────
# Create bots via @BotFather on Telegram
PASA38_BOT_TOKEN=your-telegram-bot-token
REYMEN_BOT_TOKEN=your-reymen-bot-token
KIRAL38_BOT_TOKEN=your-kiral38-bot-token

# ─── Discord (optional) ──────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id

# ─── Gateway Platforms (optional) ────────────────────────────────
# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Microsoft Teams
TEAMS_TENANT_ID=your-tenant-id
TEAMS_CLIENT_ID=your-client-id
TEAMS_CLIENT_SECRET=your-client-secret

# Home Assistant
HASS_TOKEN=your-long-lived-access-token
HASS_HOST=http://homeassistant.local:8123

# Signal
SIGNAL_URL=http://localhost:8080
SIGNAL_NUMBER=+905551234567

# Matrix
MATRIX_HOMESERVER_URL=https://matrix.example.com
MATRIX_ACCESS_TOKEN=your-matrix-token

# DingTalk / Feishu / WeCom
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
FEISHU_APP_ID=cli_your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# ─── Remote Environments (optional) ──────────────────────────────
# SSH
SSH_HOST=your-server.com
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=
SSH_KEY_PATH=~/.ssh/id_rsa

# Daytona Cloud Sandbox
DAYTONA_API_KEY=your-daytona-api-key
DAYTONA_TARGET=us

# ─── MCP Servers (optional) ──────────────────────────────────────
# MCP OAuth tokens for external services

# ─── Web Search (optional) ───────────────────────────────────────
# FIREWORKS_API_KEY=sk-your-fireworks-key  # for Firecrawl
